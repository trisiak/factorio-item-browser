  "main": "src/index.tsx",
  "scripts": {
    "analyze": "source-map-explorer --no-border-checks \"build/asset/js/!(images*).js\"",
    "build": "webpack --mode production",
    "e2e:build": "([ -f .env ] || cp .env.development .env) && BASE_PATH=/factorio-item-browser/ npm run build",
    "e2e:serve": "([ -f build/404.html ] || npm run e2e:build) && node e2e/server.js",
    "fix": "eslint src --fix",
    "start": "webpack serve --mode development",
    "test": "npm run test-tsc && npm run test-jest && npm run test-eslint",
    "test-eslint": "eslint src",
    "test-jest": "jest",
    "test-tsc": "tsc",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:tour": "playwright test --project=tour"
  },
  "browserslist": [
    ">1%"
  ]
}
